rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function adminRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function isAdmin() {
      return request.auth != null &&
        (
          adminRole() == 'admin' ||
          adminRole() == 'Admin' ||
          adminRole() == 'ADMIN' ||
          adminRole() == 'administrador' ||
          adminRole() == 'Administrador' ||
          adminRole() == 'administrator' ||
          adminRole() == 'Administrator'
        );
    }
    
    match /usuarios/{userId} {
      allow read, write: if request.auth != null;
    }
    
    match /materias/{materiaId} {
      allow read, write: if request.auth != null;
    }

    match /docentes/{docenteId} {
      allow read, write: if request.auth != null;
    }

    match /secciones/{seccionId} {
      allow read, write: if request.auth != null;
    }

    match /anuncios/{anuncioId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /inscripciones/{inscripcionId} {
      allow read, write: if request.auth != null;
    }
    
    match /reportes/{reporteId} {
      allow read, write: if request.auth != null;
    }
    
    match /publicaciones/{publicacionId} {
      allow read, write: if request.auth != null;
    }
    
    match /estadisticasUsuario/{estadisticaId} {
      allow read, write: if request.auth != null;
    }
    
    match /notificaciones/{notificationId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
    
    match /notificacionesUsuario/{notifUsuarioId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    
    match /notificationSettings/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /archivos/{archivoId} {
      allow read, write: if request.auth != null;
    }
    
    match /tiposArchivo/{tipoId} {
      allow read, write: if request.auth != null;
    }
    
    match /likes/{document} {
      allow read, write: if request.auth != null;
    }

    match /comentarios/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /actividad_reciente/{actividadId} {
      allow read: if isAdmin();
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
