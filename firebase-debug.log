[debug] [2026-03-22T13:28:36.709Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/mobile-1dae0/rulesets {"name":"projects/mobile-1dae0/rulesets/78559247-d210-45cb-ad3c-52a9a1cf74f8","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function adminRole() {\n      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;\n    }\n\n    function isAdmin() {\n      return request.auth != null &&\n        (adminRole() == 'admin' || adminRole() == 'administrador' || adminRole() == 'administrator');\n    }\n    \r\n    match /usuarios/{userId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /materias/{materiaId} {\n      allow read, write: if request.auth != null;\n    }\n\n    match /docentes/{docenteId} {\n      allow read, write: if request.auth != null;\n    }\n\n    match /secciones/{seccionId} {\n      allow read, write: if request.auth != null;\n    }\n\n    match /anuncios/{anuncioId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n    \r\n    match /inscripciones/{inscripcionId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /reportes/{reporteId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /publicaciones/{publicacionId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /estadisticasUsuario/{estadisticaId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /notificaciones/{notificationId} {\r\n      allow read: if request.auth != null;\r\n      allow create: if request.auth != null;\r\n      allow update, delete: if false;\r\n    }\r\n    \r\n    match /notificacionesUsuario/{notifUsuarioId} {\r\n      allow read: if request.auth != null && resource.data.userId == request.auth.uid;\r\n      allow create: if request.auth != null;\r\n      allow update: if request.auth != null && resource.data.userId == request.auth.uid;\r\n      allow delete: if false;\r\n    }\r\n    \r\n    match /notificationSettings/{userId} {\r\n      allow read: if request.auth != null;\r\n      allow write: if request.auth != null && request.auth.uid == userId;\r\n    }\r\n    \r\n    match /archivos/{archivoId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /tiposArchivo/{tipoId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /likes/{document} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n\r\n    match /comentarios/{document} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /actividad_reciente/{actividadId} {\n      allow read: if isAdmin();\n      allow create: if request.auth != null;\n      allow update, delete: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-22T13:28:35.943359Z","metadata":{"services":["cloud.firestore"]}}
