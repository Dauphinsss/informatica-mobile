[debug] [2026-03-22T15:08:13.630Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/mobile-1dae0/rulesets {"name":"projects/mobile-1dae0/rulesets/d01a4742-2d66-4ac1-aef3-2173dffcba76","source":{"files":[{"content":"rules_version = '2';\r\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    function adminRole() {\n      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;\n    }\n\n    function isAdmin() {\n      return request.auth != null &&\n        (\n          adminRole() == 'admin' ||\n          adminRole() == 'Admin' ||\n          adminRole() == 'ADMIN' ||\n          adminRole() == 'administrador' ||\n          adminRole() == 'Administrador' ||\n          adminRole() == 'administrator' ||\n          adminRole() == 'Administrator'\n        );\n    }\n    \r\n    match /usuarios/{userId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /materias/{materiaId} {\n      allow read, write: if request.auth != null;\n    }\n\n    match /docentes/{docenteId} {\n      allow read, write: if request.auth != null;\n    }\n\n    match /secciones/{seccionId} {\n      allow read, write: if request.auth != null;\n    }\n\n    match /anuncios/{anuncioId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n\n    match /configuracionSistema/{configId} {\n      allow read: if request.auth != null;\n      allow write: if isAdmin();\n    }\n    \r\n    match /inscripciones/{inscripcionId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /reportes/{reporteId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /publicaciones/{publicacionId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /estadisticasUsuario/{estadisticaId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /notificaciones/{notificationId} {\r\n      allow read: if request.auth != null;\r\n      allow create: if request.auth != null;\r\n      allow update, delete: if false;\r\n    }\r\n    \r\n    match /notificacionesUsuario/{notifUsuarioId} {\r\n      allow read: if request.auth != null && resource.data.userId == request.auth.uid;\r\n      allow create: if request.auth != null;\r\n      allow update: if request.auth != null && resource.data.userId == request.auth.uid;\r\n      allow delete: if false;\r\n    }\r\n    \r\n    match /notificationSettings/{userId} {\r\n      allow read: if request.auth != null;\r\n      allow write: if request.auth != null && request.auth.uid == userId;\r\n    }\r\n    \r\n    match /archivos/{archivoId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /tiposArchivo/{tipoId} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /likes/{document} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n\r\n    match /comentarios/{document} {\r\n      allow read, write: if request.auth != null;\r\n    }\r\n    \r\n    match /actividad_reciente/{actividadId} {\n      allow read: if isAdmin();\n      allow create: if request.auth != null;\n      allow update, delete: if false;\n    }\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-03-22T15:08:12.939087Z","metadata":{"services":["cloud.firestore"]}}
